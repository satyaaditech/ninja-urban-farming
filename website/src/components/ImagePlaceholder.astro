---
export interface Props {
  src?: string;
  alt?: string;
  caption?: string;
  width?: string;
  height?: string;
}

const { 
  src, 
  alt = 'Ilustrasi', 
  caption = '', 
  width = '100%', 
  height = 'auto' 
} = Astro.props;
---

<figure class="image-wrapper" style={`width: ${width};`}>
  {src ? (
    <div class="image-frame">
      <img src={src} alt={alt} loading="lazy" style={`width: 100%; height: ${height}; object-fit: cover;`} />
    </div>
  ) : (
    <div class="placeholder-box" style={`height: ${height === 'auto' ? '280px' : height};`}>
      <div class="placeholder-pattern"></div>
      <div class="placeholder-content">
        <div class="placeholder-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <circle cx="8.5" cy="8.5" r="1.5"></circle>
            <polyline points="21 15 16 10 5 21"></polyline>
          </svg>
        </div>
        <div class="placeholder-title">{alt}</div>
        {caption && <div class="placeholder-caption">{caption}</div>}
      </div>
    </div>
  )}
  {caption && src && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .image-wrapper {
    margin: 2.5rem 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  
  .image-frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border);
  }
  
  .image-frame img {
    display: block;
    border-radius: var(--radius-lg);
  }
  
  .placeholder-box {
    position: relative;
    background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
    border: 2px dashed var(--color-primary-300);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
    min-height: 280px;
    overflow: hidden;
  }
  
  .placeholder-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.4;
    background-image: 
      radial-gradient(circle at 20% 80%, var(--color-primary-300) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, var(--color-accent-400) 0%, transparent 40%);
  }
  
  .placeholder-content {
    position: relative;
    z-index: 1;
    max-width: 80%;
  }
  
  .placeholder-icon {
    color: var(--color-primary-600);
    margin-bottom: 1rem;
    display: inline-flex;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 50%;
    backdrop-filter: blur(4px);
  }
  
  .placeholder-title {
    font-weight: 700;
    color: var(--color-primary-900);
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }
  
  .placeholder-caption {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  
  figcaption {
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-top: 0.75rem;
    font-style: italic;
  }
</style>
