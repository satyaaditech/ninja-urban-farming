---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Ninja Urban Farming', 
  description = 'Panduan praktis pertanian perkotaan berbasis sistem closed-loop organik untuk Indonesia.' 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/ninja-urban-farming/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    /* Primary Palette */
    --color-primary-900: #052e16;
    --color-primary-800: #064e3b;
    --color-primary-700: #047857;
    --color-primary-600: #059669;
    --color-primary-500: #10b981;
    --color-primary-400: #34d399;
    --color-primary-300: #6ee7b7;
    --color-primary-100: #d1fae5;
    --color-primary-50: #ecfdf5;
    
    /* Accent Palette */
    --color-accent-600: #d97706;
    --color-accent-500: #f59e0b;
    --color-accent-400: #fbbf24;
    --color-accent-100: #fef3c7;
    
    /* Neutral Palette */
    --color-bg: #fafaf9;
    --color-surface: #ffffff;
    --color-text: #1e293b;
    --color-text-secondary: #64748b;
    --color-text-muted: #94a3b8;
    --color-border: #e2e8f0;
    --color-border-light: #f1f5f9;
    
    /* Typography */
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --font-serif: 'Merriweather', Georgia, serif;
    
    /* Spacing */
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --radius-xl: 24px;
    
    /* Shadows */
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
    
    /* Layout */
    --max-width: 1200px;
    --header-height: 72px;
  }
  
  * {
    box-sizing: border-box;
  }
  
  html {
    scroll-behavior: smooth;
  }
  
  body {
    font-family: var(--font-sans);
    margin: 0;
    padding: 0;
    color: var(--color-text);
    line-height: 1.7;
    background: var(--color-bg);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  
  main {
    min-height: calc(100vh - var(--header-height) - 280px);
  }
  
  h1, h2, h3, h4, h5, h6 {
    color: var(--color-primary-900);
    line-height: 1.25;
    font-weight: 700;
    margin-top: 0;
  }
  
  h1 { font-size: clamp(2.5rem, 5vw, 4rem); }
  h2 { font-size: clamp(1.75rem, 3vw, 2.5rem); }
  h3 { font-size: clamp(1.25rem, 2vw, 1.5rem); }
  
  a {
    color: var(--color-primary-700);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  a:hover {
    color: var(--color-primary-600);
  }
  
  p {
    margin-top: 0;
    margin-bottom: 1.25rem;
  }
  
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  
  /* Page Header */
  .page-header {
    background: linear-gradient(135deg, var(--color-primary-900) 0%, var(--color-primary-700) 50%, var(--color-primary-600) 100%);
    color: white;
    padding: clamp(4rem, 10vw, 7rem) 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  
  .page-header h1 {
    color: white;
    margin: 0 0 1rem 0;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  
  .page-header p {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    margin: 0 auto;
    max-width: 700px;
    opacity: 0.92;
    line-height: 1.6;
  }
  
  /* Sections */
  .section {
    padding: clamp(4rem, 8vw, 6rem) 1.5rem;
  }
  
  .section-alt {
    background: var(--color-surface);
  }
  
  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 3.5rem;
  }
  
  .section-header h2 {
    margin-bottom: 1rem;
  }
  
  .section-header p {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
    margin-bottom: 0;
  }
  
  /* Cards */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.75rem;
  }
  
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-primary-200);
  }
  
  .card h3 {
    margin-top: 0;
    margin-bottom: 0.75rem;
    color: var(--color-primary-900);
  }
  
  .card p {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }
  
  .card-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    display: inline-block;
  }
  
  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--color-primary-700);
    color: white;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    border: none;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
  }
  
  .btn:hover {
    background: var(--color-primary-800);
    color: white;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }
  
  .btn-outline {
    background: transparent;
    color: var(--color-primary-700);
    border: 2px solid var(--color-primary-200);
  }
  
  .btn-outline:hover {
    background: var(--color-primary-50);
    border-color: var(--color-primary-300);
  }
  
  .btn-accent {
    background: var(--color-accent-500);
    color: var(--color-primary-900);
  }
  
  .btn-accent:hover {
    background: var(--color-accent-400);
  }
  
  /* Tags */
  .tag {
    display: inline-flex;
    align-items: center;
    background: var(--color-primary-100);
    color: var(--color-primary-800);
    padding: 0.35rem 0.9rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin-right: 0.5rem;
    margin-bottom: 0.5rem;
  }
  
  .tag-accent {
    background: var(--color-accent-100);
    color: var(--color-accent-600);
  }
  
  /* Prose untuk konten Markdown */
  .prose {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
    font-family: var(--font-serif);
    font-size: 1.05rem;
  }
  
  .prose h1, .prose h2, .prose h3, .prose h4 {
    font-family: var(--font-sans);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .prose h1 { font-size: 2.5rem; }
  .prose h2 { 
    font-size: 1.75rem; 
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-border-light);
  }
  .prose h3 { font-size: 1.35rem; }
  
  .prose p {
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }
  
  .prose ul, .prose ol {
    margin-bottom: 1.5rem;
    padding-left: 1.75rem;
  }
  
  .prose li {
    margin-bottom: 0.5rem;
  }
  
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    box-shadow: var(--shadow-sm);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: block;
    overflow-x: auto;
  }
  
  .prose th, .prose td {
    border: 1px solid var(--color-border);
    padding: 0.875rem 1rem;
    text-align: left;
  }
  
  .prose th {
    background: var(--color-primary-50);
    font-weight: 700;
    color: var(--color-primary-900);
    white-space: nowrap;
  }
  
  .prose tr:nth-child(even) {
    background: var(--color-bg);
  }
  
  .prose blockquote {
    border-left: 4px solid var(--color-primary-500);
    margin: 2rem 0;
    padding: 1.25rem 1.75rem;
    background: var(--color-primary-50);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    color: var(--color-primary-900);
  }
  
  .prose blockquote p:last-child {
    margin-bottom: 0;
  }
  
  .prose code {
    background: var(--color-border-light);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.85em;
    font-family: 'SF Mono', Monaco, monospace;
    color: var(--color-primary-800);
  }
  
  .prose pre {
    background: var(--color-primary-900);
    color: #f9fafb;
    padding: 1.25rem;
    border-radius: var(--radius-md);
    overflow-x: auto;
    font-family: 'SF Mono', Monaco, monospace;
    margin: 1.5rem 0;
  }
  
  .prose pre code {
    background: transparent;
    color: inherit;
    padding: 0;
  }
  
  .prose hr {
    border: none;
    border-top: 2px solid var(--color-border-light);
    margin: 3rem 0;
  }
  
  /* Utilities */
  .text-center { text-align: center; }
  .mt-0 { margin-top: 0; }
  .mb-0 { margin-bottom: 0; }
  .mt-2 { margin-top: 2rem; }
  .mb-2 { margin-bottom: 2rem; }
  
  @media (max-width: 768px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
    
    .prose {
      padding: 2rem 1rem 4rem;
    }
  }
</style>
