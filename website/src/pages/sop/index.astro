---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const sops = await getCollection('sop');
const sortedSops = sops.sort((a, b) => a.data.title.localeCompare(b.data.title));

const categories = [...new Set(sortedSops.map(sop => sop.data.tags[0] || 'SOP'))];
---

<Layout 
  title="SOP Budidaya — Ninja Urban Farming" 
  description="Kumpulan Standard Operating Procedure budidaya sayuran, ikan, dan unggas dalam sistem closed-loop organik."
>
  <header class="page-header">
    <div class="container">
      <h1>📋 SOP Budidaya</h1>
      <p>Panduan operasional lengkap dari benih hingga panen. Ikuti langkahnya, catat progresnya.</p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="filter-bar">
        <span class="filter-label">Filter:</span>
        <button class="filter-btn active" data-filter="all">Semua</button>
        {categories.map(cat => (
          <button class="filter-btn" data-filter={cat}>{cat}</button>
        ))}
      </div>
      
      <div class="card-grid" id="sopGrid">
        {sortedSops.map(sop => (
          <article class="card sop-card" data-category={sop.data.tags[0] || 'SOP'}>
            <div class="card-meta">
              <span class="tag">{sop.data.tags[0] || 'SOP'}</span>
            </div>
            <h3>{sop.data.title}</h3>
            <p>{sop.data.description}</p>
            <a href={`/ninja-urban-farming/sop/${sop.id}`} class="btn btn-sm">Baca SOP →</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const sopCards = document.querySelectorAll('.sop-card');
  
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      sopCards.forEach(card => {
        const category = card.dataset.category;
        if (filter === 'all' || category === filter) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .filter-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  
  .filter-label {
    font-weight: 600;
    color: var(--color-text-secondary);
  }
  
  .filter-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    background: white;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.2s ease;
    text-transform: lowercase;
  }
  
  .filter-btn:hover {
    border-color: var(--color-primary-300);
    color: var(--color-primary-700);
  }
  
  .filter-btn.active {
    background: var(--color-primary-700);
    color: white;
    border-color: var(--color-primary-700);
  }
  
  .sop-card {
    border-top: 4px solid var(--color-primary-500);
  }
  
  .card-meta {
    margin-bottom: 0.75rem;
  }
  
  .sop-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.75rem;
  }
  
  .btn-sm {
    padding: 0.65rem 1.25rem;
    font-size: 0.875rem;
  }
</style>
