---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';

export async function getStaticPaths() {
  const sops = await getCollection('sop');
  return sops.map(sop => ({
    params: { slug: sop.id },
    props: { sop }
  }));
}

type Props = {
  sop: CollectionEntry<'sop'>;
};

const { sop } = Astro.props;
const { Content } = await render(sop);
---

<Layout 
  title={`${sop.data.title} — Ninja Urban Farming`} 
  description={sop.data.description}
>
  <article class="sop-detail">
    <header class="sop-header">
      <div class="container">
        <div class="sop-header-content">
          <div class="sop-breadcrumbs">
            <a href="/ninja-urban-farming/">Beranda</a>
            <span>/</span>
            <a href="/ninja-urban-farming/sop">SOP</a>
            <span>/</span>
            <span>{sop.data.title}</span>
          </div>
          <h1>{sop.data.title}</h1>
          <p class="sop-description">{sop.data.description}</p>
          <div class="sop-meta">
            <span class="tag">{sop.data.category}</span>
            {sop.data.tags.map(tag => <span class="tag tag-accent">{tag}</span>)}
            <span class="sop-date">Diperbarui: {sop.data.pubDate.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          </div>
        </div>
      </div>
    </header>
    
    <div class="prose">
      <Content />
    </div>
    
    <div class="sop-footer container">
      <a href="/ninja-urban-farming/sop" class="btn btn-outline">← Kembali ke Daftar SOP</a>
    </div>
  </article>
</Layout>

<style>
  .sop-detail {
    background: var(--color-bg);
  }
  
  .sop-header {
    background: linear-gradient(135deg, var(--color-primary-900) 0%, var(--color-primary-700) 100%);
    color: white;
    padding: clamp(3rem, 8vw, 5rem) 0;
    margin-bottom: 2rem;
  }
  
  .sop-header-content {
    max-width: 800px;
  }
  
  .sop-breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    opacity: 0.85;
    flex-wrap: wrap;
  }
  
  .sop-breadcrumbs a {
    color: var(--color-primary-300);
  }
  
  .sop-breadcrumbs a:hover {
    color: white;
  }
  
  .sop-header h1 {
    color: white;
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
  }
  
  .sop-description {
    font-size: 1.15rem;
    opacity: 0.92;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  
  .sop-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  
  .sop-meta .tag {
    background: rgba(255, 255, 255, 0.2);
    color: white;
  }
  
  .sop-date {
    font-size: 0.875rem;
    opacity: 0.8;
    margin-left: 0.5rem;
  }
  
  .prose {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    margin-top: -3rem;
    position: relative;
    z-index: 1;
    padding: 3rem 2.5rem;
  }
  
  .sop-footer {
    padding: 3rem 0 5rem;
    text-align: center;
  }
  
  @media (max-width: 768px) {
    .prose {
      padding: 2rem 1.25rem;
      margin-top: -2rem;
    }
  }
</style>
