---
import Layout from '../layouts/Layout.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import { getCollection } from 'astro:content';

const sops = await getCollection('sop');
const latestSops = sops
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<Layout 
  title="Ninja Urban Farming — Panduan Pertanian Perkotaan" 
  description="Panduan praktis budidaya sayuran, ikan, dan unggas dalam sistem closed-loop organik untuk petani kota Indonesia."
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-pattern"></div>
    <div class="hero-container container">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          Sistem Closed-Loop Organik
        </div>
        <h1 class="hero-title">
          Pertanian Perkotaan yang <span class="text-gradient">Berkelanjutan</span>
        </h1>
        <p class="hero-subtitle">
          Panduan lengkap untuk bertani di lahan terbatas. Ubah limbah dapur menjadi nutrisi, 
          budidayakan ikan dan sayuran sendiri, dan ciptakan ekosistem pertanian mandiri di rumahmu.
        </p>
        <div class="hero-actions">
          <a href="/ninja-urban-farming/sop" class="btn btn-lg">Mulai Bertani</a>
          <a href="/ninja-urban-farming/tentang" class="btn btn-outline btn-lg">Pelajari Sistem</a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-number">8+</span>
            <span class="hero-stat-label">SOP Budidaya</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-number">50+</span>
            <span class="hero-stat-label">Resep Formula</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-number">100%</span>
            <span class="hero-stat-label">Organik</span>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <ImagePlaceholder 
          alt="Ilustrasi Sistem Closed-Loop Ninja" 
          caption="Ilustrasi isometrik sistem urban farming: raised bed sayuran di atas, kolam lele bioflok di bawah, komposter BSF di samping, dan ayam petelur. Warna hijau dominan dengan aksen oranye, gaya flat modern, latar putih bersih."
          height="500px"
        />
      </div>
    </div>
  </section>

  <!-- Closed Loop System -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Sistem Closed-Loop Ninja</h2>
        <p>
          Setiap komponen saling terhubung. Tidak ada limbah yang terbuang — semuanya menjadi sumber daya 
          untuk komponen berikutnya.
        </p>
      </div>
      
      <div class="card-grid">
        <div class="card system-card">
          <div class="card-icon-bg">🐛</div>
          <h3>Maggot BSF</h3>
          <p>Mengubah limbah organik dapur menjadi protein tinggi untuk pakan lele dan ayam.</p>
          <span class="system-arrow">↓</span>
        </div>
        <div class="card system-card">
          <div class="card-icon-bg">🐟</div>
          <h3>Lele Bioflok</h3>
          <p>Budidaya lele dalam galon dengan sistem bioflok — ikan sehat, air kaya nutrisi.</p>
          <span class="system-arrow">↓</span>
        </div>
        <div class="card system-card">
          <div class="card-icon-bg">🌿</div>
          <h3>Raised Bed Sayuran</h3>
          <p>Air lele dan kompos menjadi pupuk alami untuk sayuran daun, tomat, cabai, dan rempah.</p>
          <span class="system-arrow">↓</span>
        </div>
        <div class="card system-card">
          <div class="card-icon-bg">🐔</div>
          <h3>Ayam Deep Litter</h3>
          <p>Unggas yang menghasilkan telur sekaligus pupuk kandang untuk kompos.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest SOPs -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>SOP Budidaya Terbaru</h2>
        <p>Panduan langkah-demi-langkah yang sudah kami susun berdasarkan praktik lapangan.</p>
      </div>
      
      <div class="card-grid">
        {latestSops.map(sop => (
          <div class="card sop-card">
            <div class="card-meta">
              <span class="tag">{sop.data.category}</span>
              <span class="card-date">{sop.data.pubDate.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
            </div>
            <h3>{sop.data.title}</h3>
            <p>{sop.data.description}</p>
            <div class="card-tags">
              {sop.data.tags.slice(0, 3).map(tag => (
                <span class="mini-tag">{tag}</span>
              ))}
            </div>
            <a href={`/ninja-urban-farming/sop/${sop.id}`} class="btn btn-sm">Baca SOP →</a>
          </div>
        ))}
      </div>
      
      <div class="text-center mt-2">
        <a href="/ninja-urban-farming/sop" class="btn btn-outline">Lihat Semua SOP</a>
      </div>
    </div>
  </section>

  <!-- Getting Started -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Mulai dari Mana?</h2>
        <p>Pilih jalur yang paling sesuai dengan pengalaman dan kebutuhanmu.</p>
      </div>
      <div class="card-grid">
        <div class="card path-card">
          <div class="path-number">01</div>
          <h3>🌱 Pemula</h3>
          <p>Mulai dari sayuran termudah: kangkung dan bayam. Siap panen dalam 20-30 hari.</p>
          <a href="/ninja-urban-farming/sop/sop-kangkung" class="btn">SOP Kangkung</a>
        </div>
        <div class="card path-card">
          <div class="path-number">02</div>
          <h3>🔬 Formula</h3>
          <p>Pelajari ramuan organik: Aminor-Grow, K-Booster, Cal-Phos, Eco-Enzyme, dan lainnya.</p>
          <a href="/ninja-urban-farming/katalog" class="btn">Katalog Resep</a>
        </div>
        <div class="card path-card">
          <div class="path-number">03</div>
          <h3>🏥 Diagnosa</h3>
          <p>Tanaman atau ikan bermasalah? Cek panduan klinis kami.</p>
          <a href="/ninja-urban-farming/klinis" class="btn">Klinis</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary-900) 0%, var(--color-primary-800) 50%, var(--color-primary-700) 100%);
    color: white;
    padding: clamp(4rem, 10vw, 6rem) 0;
    position: relative;
    overflow: hidden;
  }
  
  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  
  .hero-container {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    width: fit-content;
  }
  
  .hero-badge-dot {
    width: 8px;
    height: 8px;
    background: var(--color-accent-400);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  
  .hero-title {
    color: white;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }
  
  .text-gradient {
    background: linear-gradient(135deg, var(--color-accent-400) 0%, var(--color-primary-300) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    opacity: 0.9;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 540px;
  }
  
  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }
  
  .btn-lg {
    padding: 1rem 2rem;
    font-size: 1.05rem;
  }
  
  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .hero-visual .image-wrapper {
    width: 100%;
    max-width: 560px;
    margin: 0;
  }
  
  .hero-stats {
    display: flex;
    gap: 2.5rem;
  }
  
  .hero-stat {
    display: flex;
    flex-direction: column;
  }
  
  .hero-stat-number {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-accent-400);
    line-height: 1;
  }
  
  .hero-stat-label {
    font-size: 0.9rem;
    opacity: 0.85;
    margin-top: 0.35rem;
  }
  
  .system-card {
    position: relative;
    text-align: center;
    padding-top: 2.5rem;
  }
  
  .card-icon-bg {
    width: 64px;
    height: 64px;
    background: var(--color-primary-50);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    margin: 0 auto 1.25rem;
  }
  
  .system-arrow {
    display: none;
  }
  
  .sop-card {
    border-top: 4px solid var(--color-primary-500);
  }
  
  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .card-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }
  
  .mini-tag {
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    background: var(--color-border-light);
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    text-transform: lowercase;
  }
  
  .btn-sm {
    padding: 0.65rem 1.25rem;
    font-size: 0.875rem;
  }
  
  .path-card {
    position: relative;
    overflow: hidden;
  }
  
  .path-number {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--color-border);
    line-height: 1;
    z-index: 0;
  }
  
  .path-card h3 {
    position: relative;
    z-index: 1;
  }
  
  .path-card p {
    position: relative;
    z-index: 1;
  }
  
  .path-card .btn {
    position: relative;
    z-index: 1;
  }
  
  @media (max-width: 992px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }
    
    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }
    
    .hero-actions {
      justify-content: center;
    }
    
    .hero-stats {
      justify-content: center;
    }
  }
  
  @media (max-width: 768px) {
    .hero-stats {
      gap: 1.5rem;
    }
    
    .system-arrow {
      display: block;
      font-size: 1.5rem;
      color: var(--color-primary-300);
      margin-top: 0.5rem;
    }
  }
</style>
